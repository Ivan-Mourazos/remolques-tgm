# Datos: "file" (desarrollo, carpeta data/) o "mssql" (producción, BD que asigne IT)
DATASOURCE=file
DB_HOST=
DB_PORT=1433
DB_DATABASE=
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
# RPS (solo lectura, catálogo de materiales). Sin estos valores se usa la
# semilla local de materiales. Rellenar en el servidor, nunca commitear.
RPS_DB_HOST=
RPS_DB_PORT=1433
RPS_DB_DATABASE=
RPS_DB_USER=
RPS_DB_PASSWORD=

# Archivo PDF en el servidor Linux. Deben configurarse las dos o ninguna.
# Ruta absoluta que Linux tenga asignada a la carpeta compartida PLANTEAMIENTOS.
RUTA_PLANTEAMIENTOS=
# Ruta absoluta Linux de OFICINA TÉCNICA; la app añadirá /<año-del-pedido>.
RUTA_OFICINA_TECNICA=
